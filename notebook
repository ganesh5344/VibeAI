        "def detect_mood(text):\n",
        "\n",
        "    text=text.lower()\n",
        "\n",
        "    scores={}\n",
        "\n",
        "    for mood,words in mood_keywords.items():\n",
        "\n",
        "        scores[mood]=sum(w in text for w in words)\n",
        "\n",
        "    return max(scores,key=scores.get)"
      ],
      "metadata": {
        "id": "ql-GZtG7IeTt"
      },
      "execution_count": 21,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def detect_genres(text):\n",
        "\n",
        "    text=text.lower()\n",
        "\n",
        "    found=[]\n",
        "\n",
        "    for genre,words in genre_keywords.items():\n",
        "\n",
        "        if any(w in text for w in words):\n",
        "\n",
        "            found.append(genre)\n",
        "\n",
        "    return found[:3]"
      ],
      "metadata": {
        "id": "-WS1yJXaIfkp"
      },
      "execution_count": 22,
      "outputs": []
    },
