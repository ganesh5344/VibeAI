        "def generate_playlist(mood,genres):\n",
        "\n",
        "    feedback_message = \"\"\n",
        "\n",
        "    results=df[df[\"mood\"]==mood]\n",
        "\n",
        "    if genres:\n",
        "\n",
        "        results=results[results[\"genre\"].isin(genres)]\n",
        "\n",
        "    if len(results)==0:\n",
        "\n",
        "        results=df.sample(min(5,len(df))) # Sample from entire df if no specific matches\n",
        "        # feedback_message = \"Note: No exact matches found for your criteria, so some random songs were selected.\\n\"\n",
        "\n",
        "    selected=results.sample(min(5,len(results)))\n",
        "\n",
        "    # Construct a more general playlist search query based on detected mood and genres\n",
        "    playlist_query_terms = [mood]\n",
        "    if genres:\n",
        "        playlist_query_terms.extend(genres)\n",
        "    playlist_query_terms.append(\"playlist\")\n",
        "    general_playlist_query = \" \".join(playlist_query_terms)\n",
        "\n",
        "    # Use URL encoding for the search query\n",
        "    encoded_query = quote_plus(general_playlist_query)\n",
        "\n",
        "    yt_link=f\"https://www.youtube.com/results?search_query={encoded_query}\"\n",
        "    sp_link=f\"https://open.spotify.com/search/{encoded_query}\"\n",
        "\n",
        "    return selected,yt_link,sp_link,feedback_message"
      ],
      "metadata": {
        "id": "WVG2suOeIhBf"
      },
      "execution_count": 30,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def vibeai_chat(text):\n",
        "\n",
        "    mood=detect_mood(text)\n",
        "\n",
        "    genres=detect_genres(text)\n",
        "\n",
        "    playlist,yt,sp,feedback_message=generate_playlist(mood,genres)\n",
        "\n",
        "    reply=f\"\"\"\n",
        "Detected mood: {mood}\n",
        "\n",
        "Detected genres: {genres if genres else 'any'}\n",
        "\n",
        "# {feedback_message}Recommended songs:\n",
        "Recommended songs:\n",
        "\"\"\"\n",
        "\n",
        "    for i,row in playlist.iterrows():\n",
        "\n",
        "        reply+=f\"{row['song']} - {row['artist']}\\n\"\n",
        "\n",
        "    reply+=f\"\"\"\n",
        "\n",
        "Listen playlist:\n",
        "\n",
        "YouTube:\n",
        "{yt}\n",
        "\n",
        "Spotify:\n",
        "{sp}\n",
        "\"\"\"\n",
        "\n",
        "    return reply"
      ],
